[Unit]
Description=RiveScript Learning Lab FastAPI
After=network.target

[Service]
Type=simple
WorkingDirectory=/www/wwwroot/rivescript-app
ExecStart=/www/wwwroot/rivescript-app/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8017 --proxy-headers
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
